}

// ====== MENU MANAGEMENT ======
function renderMenuMgmt() {
  const el = document.getElementById('menuMgmtContent');
  el.innerHTML = `<div class="table-wrap"><table>
    <thead><tr><th>Item</th><th>Category</th><th>Selling Price</th><th>Cost</th><th>Margin</th><th>Stock</th><th>Status</th><th>Actions</th></tr></thead>
    <tbody>${DB.menuItems.map(m=>{
      const margin = m.price>0?Math.round((m.price-m.cost)/m.price*100):0;
      const stockStatus = m.stock<=0?'Out':m.stock<=m.minStock?'Low':'OK';
      return `<tr>
        <td><span style="font-size:18px;margin-right:6px">${m.emoji||'🍽️'}</span><strong>${m.name}</strong></td>
        <td>${m.cat}</td>
        <td>₨${m.price}</td>
        <td>₨${m.cost}</td>
        <td><span style="color:${margin>=40?'var(--green)':margin>=20?'var(--gold)':'var(--red)'}">${margin}%</span></td>
        <td>${m.stock} <span style="font-size:11px;color:var(--text3)">(min:${m.minStock})</span></td>
        <td><span class="badge ${stockStatus==='Out'?'badge-cancelled':stockStatus==='Low'?'badge-pending':'badge-done'}">${m.available?stockStatus:'Disabled'}</span></td>
        <td style="display:flex;gap:6px">
          <button class="btn btn-secondary btn-sm" onclick="editMenuItem(${m.id})">✏️</button>
          <button class="btn btn-danger btn-sm" onclick="deleteMenuItem(${m.id})">🗑️</button>
        </td>
      </tr>`;
    }).join('')}
    ${DB.menuItems.length===0?'<tr><td colspan="8"><div class="empty-state"><div class="empty-icon">🍽️</div><p>No menu items. Add one!</p></div></td></tr>':''}
    </tbody></table></div>`;
}

function openMenuModal(id) {
  editingMenuId = id||null;
  document.getElementById('menuModalTitle').innerHTML = (id?'Edit':'Add')+' Menu Item <span class="close-btn" onclick="closeModal(\'menuModal\')">✕</span>';
  if(id){
    const m = DB.menuItems.find(m=>m.id===id);
    document.getElementById('mi_name').value=m.name;
    document.getElementById('mi_cat').value=m.cat;
    document.getElementById('mi_price').value=m.price;
    document.getElementById('mi_cost').value=m.cost;
    document.getElementById('mi_stock').value=m.stock;
    document.getElementById('mi_minstock').value=m.minStock;
    document.getElementById('mi_emoji').value=m.emoji||'';
    document.getElementById('mi_available').value=m.available?'1':'0';
  } else {
    ['mi_name','mi_price','mi_cost','mi_stock','mi_minstock','mi_emoji'].forEach(id=>document.getElementById(id).value='');
    document.getElementById('mi_available').value='1';
  }
  document.getElementById('menuModal').classList.add('open');
}

function editMenuItem(id) { openMenuModal(id); }

function saveMenuItem() {
  const name = document.getElementById('mi_name').value.trim();
  const price = parseFloat(document.getElementById('mi_price').value);
  const cost = parseFloat(document.getElementById('mi_cost').value);
  if(!name||!price||!cost){ notify('Please fill all required fields','error'); return; }
  const data = {
    name, cat:document.getElementById('mi_cat').value,
    price, cost,
    stock: parseInt(document.getElementById('mi_stock').value)||0,
    minStock: parseInt(document.getElementById('mi_minstock').value)||5,
    emoji: document.getElementById('mi_emoji').value||'🍽️',
    available: document.getElementById('mi_available').value==='1'
  };
  if(editingMenuId){
    const idx = DB.menuItems.findIndex(m=>m.id===editingMenuId);
    DB.menuItems[idx] = {...DB.menuItems[idx],...data};
    notify('Item updated!','success');
  } else {
    data.id = DB.menuItems.length>0?Math.max(...DB.menuItems.map(m=>m.id))+1:1;
    DB.menuItems.push(data);
    notify('Item added!','success');
  }
  save(); closeModal('menuModal'); renderMenuMgmt();
}

function deleteMenuItem(id) {
  if(!confirm('Delete this menu item?')) return;
  DB.menuItems = DB.menuItems.filter(m=>m.id!==id);
  save(); notify('Item deleted','info'); renderMenuMgmt();
}

// ====== STOCK ======
function renderStock() {
  const lowItems = DB.menuItems.filter(m=>m.stock<=m.minStock);
  const el = document.getElementById('stockContent');
  el.innerHTML = (lowItems.length>0?`<div class="stock-warning">⚠️ ${lowItems.length} item(s) need restocking: ${lowItems.map(m=>m.name).join(', ')}</div>`:'')+`
    <div class="table-wrap"><table>
      <thead><tr><th>Item</th><th>Category</th><th>In Stock</th><th>Min Alert</th><th>Stock Level</th><th>Status</th><th>Restock</th></tr></thead>
      <tbody>${DB.menuItems.map(m=>{
        const pct = m.minStock>0?Math.min(100,Math.round(m.stock/Math.max(m.minStock*2,1)*100)):100;
        const status = m.stock<=0?'Out':m.stock<=m.minStock?'Low':'OK';
        return `<tr>
          <td><span style="margin-right:6px">${m.emoji||''}</span>${m.name}</td>
          <td>${m.cat}</td>
          <td><strong>${m.stock}</strong></td>
          <td>${m.minStock}</td>
          <td style="width:140px">
            <div class="progress-bar"><div class="progress-fill ${status==='Out'?'progress-red':status==='Low'?'progress-yellow':'progress-green'}" style="width:${pct}%"></div></div>
            <div style="font-size:11px;color:var(--text3);margin-top:2px">${pct}%</div>
          </td>
          <td><span class="badge ${status==='Out'?'badge-cancelled':status==='Low'?'badge-low':'badge-ok'}">${status}</span></td>
          <td>
            <div style="display:flex;gap:4px;align-items:center">
              <input type="number" id="restock_${m.id}" value="10" style="width:65px;padding:5px 8px;font-size:12px" min="1">
              <button class="btn btn-success btn-sm" onclick="restockItem(${m.id})">+ Add</button>
            </div>
          </td>
        </tr>`;
      }).join('')}
      </tbody></table></div>`;
}

function restockItem(id) {
  const qty = parseInt(document.getElementById(`restock_${id}`).value)||0;
  if(qty<=0){ notify('Enter a valid quantity','error'); return; }
  const m = DB.menuItems.find(m=>m.id===id);
  if(m){ m.stock+=qty; save(); notify(`✅ ${m.name} restocked by ${qty}!`,'success'); renderStock(); }
}

// ====== STAFF ======
function renderStaff() {
  const el = document.getElementById('staffContent');
  const totalSalary = DB.staff.reduce((s,st)=>s+(st.salary||0),0);
  el.innerHTML = `
    <div class="stats-grid" style="grid-template-columns:repeat(3,1fr);margin-bottom:20px">
      <div class="stat-card teal"><div class="stat-icon">👥</div><div class="stat-value">${DB.staff.length}</div><div class="stat-label">Total Staff</div></div>
      <div class="stat-card gold"><div class="stat-icon">💸</div><div class="stat-value">₨${fmt(totalSalary)}</div><div class="stat-label">Monthly Payroll</div></div>
      <div class="stat-card green"><div class="stat-icon">✅</div><div class="stat-value">${DB.staff.filter(s=>s.active).length}</div><div class="stat-label">Active Staff</div></div>
    </div>
    <div class="table-wrap"><table>
      <thead><tr><th>Staff</th><th>Role</th><th>Phone</th><th>Salary</th><th>Status</th><th>Actions</th></tr></thead>
      <tbody>${DB.staff.map(s=>`
        <tr>
          <td><div style="display:flex;align-items:center;gap:10px"><div class="staff-avatar" style="width:32px;height:32px;font-size:13px">${s.name.charAt(0)}</div>${s.name}</div></td>
          <td><span class="badge badge-${s.role==='Manager'?'pending':s.role==='Chef'?'done':'ok'}">${s.role}</span></td>
          <td>${s.phone||'-'}</td>
          <td>₨${fmt(s.salary||0)}</td>
          <td><span class="badge badge-${s.active?'done':'cancelled'}">${s.active?'Active':'Inactive'}</span></td>
          <td>
            <button class="btn btn-secondary btn-sm" onclick="toggleStaff(${s.id})">${s.active?'Deactivate':'Activate'}</button>
            <button class="btn btn-danger btn-sm" onclick="deleteStaff(${s.id})">🗑️</button>
          </td>
        </tr>`).join('')}
        ${DB.staff.length===0?'<tr><td colspan="6"><div class="empty-state"><div class="empty-icon">👥</div><p>No staff added yet</p></div></td></tr>':''}
      </tbody></table></div>`;
}

function openStaffModal() { document.getElementById('staffModal').classList.add('open'); }
function saveStaff() {
  const name = document.getElementById('st_name').value.trim();
  if(!name){ notify('Name required','error'); return; }
  DB.staff.push({
    id: DB.staff.length>0?Math.max(...DB.staff.map(s=>s.id))+1:1,
    name, role:document.getElementById('st_role').value,
    phone:document.getElementById('st_phone').value,
    salary:parseFloat(document.getElementById('st_salary').value)||0,
    active:true
  });
  save(); closeModal('staffModal'); notify('Staff added!','success'); renderStaff();
}

function toggleStaff(id) {
  const s = DB.staff.find(s=>s.id===id);
  if(s){ s.active=!s.active; save(); renderStaff(); }
}

function deleteStaff(id) {
  if(!confirm('Remove this staff member?')) return;
  DB.staff = DB.staff.filter(s=>s.id!==id);
  save(); renderStaff(); notify('Staff removed','info');
}

// ====== REPORTS ======
function renderReports() {
  const paidOrders = DB.orders.filter(o=>o.status==='paid');
  const totalRevenue = paidOrders.reduce((s,o)=>s+o.total,0);
  const totalSubtotal = paidOrders.reduce((s,o)=>s+o.subtotal,0);
  const totalVat = paidOrders.reduce((s,o)=>s+o.vat,0);
  const totalService = paidOrders.reduce((s,o)=>s+o.service,0);
  const totalCost = paidOrders.reduce((s,o)=>s+o.items.reduce((c,i)=>c+i.cost*i.qty,0),0);
  const grossProfit = totalSubtotal - totalCost;
  const netProfit = totalRevenue - totalCost;
  const margin = totalRevenue>0?Math.round(netProfit/totalRevenue*100):0;
  const monthlySalary = DB.staff.reduce((s,st)=>s+(st.salary||0),0);

  // Monthly breakdown
  const months = {};
  paidOrders.forEach(o=>{
    const key = new Date(o.timestamp).toLocaleDateString('en-US',{year:'numeric',month:'short'});
    if(!months[key]) months[key]={revenue:0,cost:0,orders:0};
    months[key].revenue+=o.total;
    months[key].cost+=o.items.reduce((c,i)=>c+i.cost*i.qty,0);
    months[key].orders++;
  });

  document.getElementById('reportsContent').innerHTML = `
    <div class="stats-grid">
      <div class="stat-card gold"><div class="stat-icon">💰</div><div class="stat-value">₨${fmt(totalRevenue)}</div><div class="stat-label">Total Revenue</div></div>
      <div class="stat-card red"><div class="stat-icon">💸</div><div class="stat-value">₨${fmt(totalCost)}</div><div class="stat-label">Total Cost</div></div>
      <div class="stat-card ${netProfit>=0?'green':'red'}"><div class="stat-icon">📈</div><div class="stat-value">₨${fmt(netProfit)}</div><div class="stat-label">Net Profit</div></div>
      <div class="stat-card teal"><div class="stat-icon">%</div><div class="stat-value">${margin}%</div><div class="stat-label">Profit Margin</div></div>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px">
      <div class="card">
        <div class="card-title">P&L Summary</div>
        <table style="margin-top:10px">
          <tbody>
            <tr><td>Food Sales</td><td style="text-align:right;color:var(--green)">₨${fmt(totalSubtotal)}</td></tr>
            <tr><td>VAT Collected</td><td style="text-align:right;color:var(--blue)">₨${fmt(totalVat)}</td></tr>
            <tr><td>Service Charge</td><td style="text-align:right;color:var(--blue)">₨${fmt(totalService)}</td></tr>
            <tr><td style="padding-top:8px;font-weight:700">Total Revenue</td><td style="text-align:right;font-weight:700;padding-top:8px;color:var(--gold)">₨${fmt(totalRevenue)}</td></tr>
            <tr><td colspan="2"><hr style="border-color:var(--border);margin:6px 0"></td></tr>
            <tr><td>Cost of Goods</td><td style="text-align:right;color:var(--red)">₨${fmt(totalCost)}</td></tr>
            <tr><td>Monthly Payroll</td><td style="text-align:right;color:var(--red)">₨${fmt(monthlySalary)}</td></tr>
            <tr><td colspan="2"><hr style="border-color:var(--border);margin:6px 0"></td></tr>
            <tr><td style="font-weight:700">Gross Profit (Food)</td><td style="text-align:right;font-weight:700;color:${grossProfit>=0?'var(--green)':'var(--red)'}">₨${fmt(grossProfit)}</td></tr>
            <tr><td style="font-weight:700">Net Profit (after pay)</td><td style="text-align:right;font-weight:700;color:${(netProfit-monthlySalary)>=0?'var(--green)':'var(--red)'}">₨${fmt(netProfit-monthlySalary)}</td></tr>
          </tbody>
        </table>
      </div>
      <div class="card">
        <div class="card-title">Order Statistics</div>
        <table style="margin-top:10px">
          <tbody>
            <tr><td>Total Orders (All)</td><td style="text-align:right">${DB.orders.length}</td></tr>
            <tr><td>Paid Orders</td><td style="text-align:right;color:var(--green)">${paidOrders.length}</td></tr>
            <tr><td>Pending Orders</td><td style="text-align:right;color:var(--gold)">${DB.orders.filter(o=>o.status==='pending').length}</td></tr>
            <tr><td>Avg Order Value</td><td style="text-align:right">₨${paidOrders.length>0?fmt(Math.round(totalRevenue/paidOrders.length)):0}</td></tr>
            <tr><td colspan="2"><hr style="border-color:var(--border);margin:6px 0"></td></tr>
            <tr><td>Menu Items</td><td style="text-align:right">${DB.menuItems.length}</td></tr>
            <tr><td>Low Stock Items</td><td style="text-align:right;color:var(--red)">${DB.menuItems.filter(m=>m.stock<=m.minStock).length}</td></tr>
            <tr><td>Active Staff</td><td style="text-align:right">${DB.staff.filter(s=>s.active).length}</td></tr>
          </tbody>
        </table>
      </div>
    </div>
    ${Object.keys(months).length>0?`
    <div class="table-wrap">
      <div class="table-header"><span class="table-title">Monthly Breakdown</span></div>
      <table>
        <thead><tr><th>Month</th><th>Orders</th><th>Revenue</th><th>Cost</th><th>Profit</th><th>Margin</th></tr></thead>
        <tbody>${Object.entries(months).map(([k,v])=>{
          const p=v.revenue-v.cost; const mg=v.revenue>0?Math.round(p/v.revenue*100):0;
          return `<tr><td>${k}</td><td>${v.orders}</td><td>₨${fmt(v.revenue)}</td><td>₨${fmt(v.cost)}</td>
            <td style="color:${p>=0?'var(--green)':'var(--red)'}"><strong>₨${fmt(p)}</strong></td>
            <td><span class="badge ${mg>=30?'badge-done':mg>=15?'badge-pending':'badge-cancelled'}">${mg}%</span></td></tr>`;
        }).join('')}</tbody>
      </table>
    </div>`:''}
  `;
}

// ====== UTILITIES ======
function fmt(n) { return Math.round(n).toLocaleString(); }
function timeSince(ts) {
  const s = Math.floor((Date.now()-ts)/1000);
  if(s<60) return s+'s'; if(s<3600) return Math.floor(s/60)+'m'; return Math.floor(s/3600)+'h';
}
function notify(msg, type='info') {
  const el = document.getElementById('notification');
  el.textContent=msg; el.className=`notif-${type}`; el.style.display='block';
  setTimeout(()=>el.style.display='none',3000);
}
function closeModal(id) { document.getElementById(id).classList.remove('open'); }
function switchTab(group, name, btn) {
  document.querySelectorAll(`[id^="${group}-"][id$="-tab"]`).forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById(`${group}-${name}-tab`).classList.add('active');
  btn.classList.add('active');
}
function updatePendingBadge() {
  const count = DB.orders.filter(o=>o.status==='pending').length;
  const badge = document.getElementById('pendingBadge');
  badge.textContent=count; badge.style.display=count>0?'':'none';
}

// Close modal on overlay click
document.querySelectorAll('.modal-overlay').forEach(overlay=>{
  overlay.addEventListener('click', e=>{ if(e.target===overlay) overlay.classList.remove('open'); });
});

// ====== INIT ======
load();
renderDashboard();
updatePendingBadge();
</script>
