<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Hotel Management System</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0d0f14;
    --surface: #141820;
    --surface2: #1c2230;
    --surface3: #242d3f;
    --border: #2a3450;
    --gold: #d4a853;
    --gold2: #f0c96e;
    --teal: #2dd4bf;
    --red: #f87171;
    --green: #4ade80;
    --blue: #60a5fa;
    --purple: #a78bfa;
    --text: #e8ecf3;
    --text2: #8b97b0;
    --text3: #5a6880;
    --radius: 12px;
    --radius-sm: 8px;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: 'DM Sans', sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; overflow-x: hidden; }

  /* SCROLLBAR */
  ::-webkit-scrollbar { width: 6px; } ::-webkit-scrollbar-track { background: var(--surface); }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }

  /* LAYOUT */
  .app { display: flex; height: 100vh; }
  .sidebar { width: 240px; min-width: 240px; background: var(--surface); border-right: 1px solid var(--border); display: flex; flex-direction: column; padding: 0; overflow: hidden; }
  .main { flex: 1; overflow-y: auto; background: var(--bg); }

  /* SIDEBAR */
  .sidebar-header { padding: 28px 20px 20px; border-bottom: 1px solid var(--border); }
  .logo { display: flex; align-items: center; gap: 10px; }
  .logo-icon { width: 38px; height: 38px; background: linear-gradient(135deg, var(--gold), #a07830); border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 18px; }
  .logo-text { font-family: 'Playfair Display', serif; font-size: 16px; font-weight: 700; color: var(--gold); line-height: 1.1; }
  .logo-sub { font-size: 10px; color: var(--text3); font-weight: 400; letter-spacing: 1px; text-transform: uppercase; }
  .sidebar-nav { flex: 1; padding: 12px 10px; overflow-y: auto; }
  .nav-section { margin-bottom: 20px; }
  .nav-label { font-size: 10px; font-weight: 600; letter-spacing: 1.5px; text-transform: uppercase; color: var(--text3); padding: 0 10px; margin-bottom: 6px; }
  .nav-item { display: flex; align-items: center; gap: 10px; padding: 9px 12px; border-radius: var(--radius-sm); cursor: pointer; color: var(--text2); font-size: 13.5px; font-weight: 500; transition: all .2s; margin-bottom: 2px; border: 1px solid transparent; }
  .nav-item:hover { background: var(--surface2); color: var(--text); }
  .nav-item.active { background: linear-gradient(135deg, rgba(212,168,83,.15), rgba(212,168,83,.05)); border-color: rgba(212,168,83,.2); color: var(--gold); }
  .nav-item .icon { font-size: 16px; width: 20px; text-align: center; }
  .nav-badge { margin-left: auto; background: var(--red); color: #fff; font-size: 10px; padding: 1px 6px; border-radius: 10px; font-weight: 600; }
  .sidebar-footer { padding: 16px 20px; border-top: 1px solid var(--border); }
  .staff-info { display: flex; align-items: center; gap: 10px; }
  .staff-avatar { width: 34px; height: 34px; border-radius: 50%; background: linear-gradient(135deg, var(--teal), #1a9e8e); display: flex; align-items: center; justify-content: center; font-size: 14px; font-weight: 700; color: #fff; }
  .staff-name { font-size: 13px; font-weight: 600; }
  .staff-role { font-size: 11px; color: var(--text3); }

  /* HEADER */
  .page-header { padding: 24px 32px 0; display: flex; align-items: center; justify-content: space-between; }
  .page-title { font-family: 'Playfair Display', serif; font-size: 26px; font-weight: 700; }
  .page-sub { font-size: 13px; color: var(--text3); margin-top: 2px; }
  .header-actions { display: flex; gap: 10px; align-items: center; }

  /* BUTTONS */
  .btn { display: inline-flex; align-items: center; gap: 7px; padding: 9px 18px; border-radius: var(--radius-sm); font-size: 13.5px; font-weight: 600; cursor: pointer; border: none; transition: all .2s; font-family: inherit; }
  .btn-primary { background: linear-gradient(135deg, var(--gold), #b8922d); color: #0d0f14; }
  .btn-primary:hover { background: linear-gradient(135deg, var(--gold2), var(--gold)); transform: translateY(-1px); box-shadow: 0 4px 16px rgba(212,168,83,.3); }
  .btn-secondary { background: var(--surface2); color: var(--text); border: 1px solid var(--border); }
  .btn-secondary:hover { background: var(--surface3); }
  .btn-danger { background: rgba(248,113,113,.15); color: var(--red); border: 1px solid rgba(248,113,113,.2); }
  .btn-danger:hover { background: rgba(248,113,113,.25); }
  .btn-success { background: rgba(74,222,128,.15); color: var(--green); border: 1px solid rgba(74,222,128,.2); }
  .btn-sm { padding: 6px 12px; font-size: 12px; }

  /* PAGES */
  .page { display: none; padding: 24px 32px 32px; animation: fadeIn .3s ease; }
  .page.active { display: block; }
  @keyframes fadeIn { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:translateY(0); } }

  /* CARDS */
  .card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 20px; }
  .card-title { font-size: 13px; font-weight: 600; color: var(--text2); text-transform: uppercase; letter-spacing: .8px; margin-bottom: 8px; }

  /* STATS GRID */
  .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 24px; }
  .stat-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 20px; position: relative; overflow: hidden; transition: transform .2s; }
  .stat-card:hover { transform: translateY(-2px); }
  .stat-card::before { content:''; position:absolute; top:0; right:0; width:80px; height:80px; border-radius: 0 var(--radius) 0 100%; opacity: .07; }
  .stat-card.gold::before { background: var(--gold); border-top-color: rgba(212,168,83,.3); }
  .stat-card.teal::before { background: var(--teal); }
  .stat-card.red::before { background: var(--red); }
  .stat-card.green::before { background: var(--green); }
  .stat-icon { font-size: 22px; margin-bottom: 12px; }
  .stat-value { font-family: 'Playfair Display', serif; font-size: 28px; font-weight: 700; line-height: 1; }
  .stat-label { font-size: 12px; color: var(--text3); margin-top: 4px; font-weight: 500; }
  .stat-change { font-size: 11px; margin-top: 8px; padding: 2px 8px; border-radius: 10px; display: inline-block; }
  .stat-change.up { background: rgba(74,222,128,.15); color: var(--green); }
  .stat-change.down { background: rgba(248,113,113,.15); color: var(--red); }

  /* TABLE */
  .table-wrap { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; }
  .table-header { padding: 16px 20px; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; }
  .table-title { font-size: 14px; font-weight: 600; }
  table { width: 100%; border-collapse: collapse; }
  th { padding: 12px 16px; text-align: left; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .8px; color: var(--text3); background: var(--surface2); border-bottom: 1px solid var(--border); }
  td { padding: 13px 16px; font-size: 13.5px; border-bottom: 1px solid rgba(42,52,80,.5); }
  tr:last-child td { border-bottom: none; }
  tr:hover td { background: rgba(255,255,255,.02); }
  .badge { display: inline-flex; align-items: center; gap: 4px; padding: 3px 10px; border-radius: 20px; font-size: 11px; font-weight: 600; }
  .badge-pending { background: rgba(212,168,83,.15); color: var(--gold); }
  .badge-done { background: rgba(74,222,128,.15); color: var(--green); }
  .badge-cancelled { background: rgba(248,113,113,.15); color: var(--red); }
  .badge-low { background: rgba(248,113,113,.15); color: var(--red); }
  .badge-ok { background: rgba(74,222,128,.15); color: var(--green); }
  .badge-mid { background: rgba(212,168,83,.15); color: var(--gold); }

  /* FORM */
  .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .form-group { display: flex; flex-direction: column; gap: 6px; }
  .form-group.full { grid-column: 1/-1; }
  label { font-size: 12px; font-weight: 600; color: var(--text2); letter-spacing: .4px; }
  input, select, textarea { background: var(--surface2); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 10px 14px; color: var(--text); font-family: inherit; font-size: 13.5px; outline: none; transition: border .2s; width: 100%; }
  input:focus, select:focus, textarea:focus { border-color: var(--gold); box-shadow: 0 0 0 3px rgba(212,168,83,.1); }
  select option { background: var(--surface2); }
  textarea { resize: vertical; min-height: 80px; }

  /* MODAL */
  .modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.7); z-index: 1000; align-items: center; justify-content: center; backdrop-filter: blur(4px); }
  .modal-overlay.open { display: flex; }
  .modal { background: var(--surface); border: 1px solid var(--border); border-radius: 16px; padding: 28px; width: 520px; max-width: 90vw; max-height: 90vh; overflow-y: auto; animation: modalIn .25s ease; }
  @keyframes modalIn { from { opacity:0; transform:scale(.95); } to { opacity:1; transform:scale(1); } }
  .modal-title { font-family: 'Playfair Display', serif; font-size: 20px; margin-bottom: 20px; display: flex; justify-content: space-between; align-items: center; }
  .close-btn { cursor: pointer; color: var(--text3); font-size: 20px; line-height:1; padding: 4px 8px; border-radius: 6px; }
  .close-btn:hover { background: var(--surface2); color: var(--text); }
  .modal-footer { display: flex; gap: 10px; justify-content: flex-end; margin-top: 24px; padding-top: 20px; border-top: 1px solid var(--border); }

  /* ORDER BUILDER */
  .order-layout { display: grid; grid-template-columns: 1fr 340px; gap: 20px; }
  .menu-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
  .menu-item { background: var(--surface2); border: 1px solid var(--border); border-radius: var(--radius); padding: 14px; cursor: pointer; transition: all .2s; }
  .menu-item:hover { border-color: var(--gold); background: var(--surface3); }
  .menu-item .item-name { font-size: 13px; font-weight: 600; margin-bottom: 4px; }
  .menu-item .item-price { font-size: 14px; font-weight: 700; color: var(--gold); }
  .menu-item .item-cat { font-size: 11px; color: var(--text3); margin-bottom: 6px; }
  .menu-category-tabs { display: flex; gap: 8px; margin-bottom: 16px; flex-wrap: wrap; }
  .cat-tab { padding: 6px 14px; border-radius: 20px; font-size: 12px; font-weight: 600; cursor: pointer; background: var(--surface2); color: var(--text2); border: 1px solid var(--border); transition: all .2s; }
  .cat-tab.active { background: rgba(212,168,83,.15); color: var(--gold); border-color: rgba(212,168,83,.3); }
  .order-cart { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; height: fit-content; position: sticky; top: 0; }
  .cart-header { padding: 16px 18px; border-bottom: 1px solid var(--border); font-weight: 700; font-size: 15px; }
  .cart-items { padding: 12px; max-height: 320px; overflow-y: auto; }
  .cart-item { display: flex; align-items: center; gap: 10px; padding: 8px 6px; border-bottom: 1px solid rgba(42,52,80,.4); }
  .cart-item:last-child { border-bottom: none; }
  .cart-item-name { flex: 1; font-size: 13px; }
  .cart-item-price { font-size: 13px; color: var(--gold); font-weight: 600; min-width: 55px; text-align: right; }
  .qty-ctrl { display: flex; align-items: center; gap: 6px; }
  .qty-btn { width: 22px; height: 22px; border-radius: 50%; border: 1px solid var(--border); background: var(--surface2); color: var(--text); cursor: pointer; font-size: 14px; line-height: 1; display: flex; align-items: center; justify-content: center; transition: all .2s; }
  .qty-btn:hover { background: var(--gold); color: #000; border-color: var(--gold); }
  .qty-num { font-size: 13px; font-weight: 700; min-width: 16px; text-align: center; }
  .cart-footer { padding: 16px 18px; border-top: 1px solid var(--border); }
  .cart-subtotal { display: flex; justify-content: space-between; font-size: 13px; color: var(--text2); margin-bottom: 6px; }
  .cart-total { display: flex; justify-content: space-between; font-size: 16px; font-weight: 700; margin-top: 10px; padding-top: 10px; border-top: 1px solid var(--border); }
  .tax-line { color: var(--text3); }
  .table-select-row { display: flex; gap: 10px; margin-bottom: 16px; align-items: center; }
  .table-select-row label { font-size: 13px; color: var(--text2); white-space: nowrap; }
  .search-bar { position: relative; }
  .search-bar input { padding-left: 36px; }
  .search-bar::before { content:'🔍'; position:absolute; left:12px; top:50%; transform:translateY(-50%); font-size:14px; z-index:1; }

  /* DASHBOARD WIDGETS */
  .dashboard-grid { display: grid; grid-template-columns: 2fr 1fr; gap: 20px; margin-top: 20px; }
  .recent-orders-list { display: flex; flex-direction: column; gap: 8px; max-height: 280px; overflow-y: auto; }
  .order-row { display: flex; align-items: center; gap: 12px; padding: 10px 14px; background: var(--surface2); border-radius: var(--radius-sm); }
  .order-row-num { font-weight: 700; color: var(--gold); font-size: 13px; width: 60px; }
  .order-row-info { flex: 1; }
  .order-row-info .name { font-size: 13px; font-weight: 600; }
  .order-row-info .time { font-size: 11px; color: var(--text3); }
  .order-row-amount { font-weight: 700; font-size: 14px; color: var(--text); }
  .top-items-list { display: flex; flex-direction: column; gap: 8px; }
  .top-item-row { display: flex; align-items: center; gap: 10px; padding: 8px 12px; background: var(--surface2); border-radius: var(--radius-sm); }
  .top-item-rank { width: 22px; height: 22px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 700; }
  .rank-1 { background: var(--gold); color: #000; }
  .rank-2 { background: #9ca3af; color: #000; }
  .rank-3 { background: #b45309; color: #fff; }
  .rank-other { background: var(--surface3); color: var(--text2); }
  .top-item-name { flex: 1; font-size: 13px; }
  .top-item-count { font-size: 12px; color: var(--text3); }

  /* PROFIT CHART */
  .chart-container { position: relative; height: 180px; margin-top: 12px; }
  .bar-chart { display: flex; align-items: flex-end; gap: 6px; height: 160px; }
  .bar-group { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 4px; }
  .bar { width: 100%; border-radius: 4px 4px 0 0; transition: height .5s ease; cursor: pointer; position: relative; }
  .bar.revenue { background: linear-gradient(180deg, var(--gold2), var(--gold)); }
  .bar.cost { background: linear-gradient(180deg, #f87171aa, #f87171); }
  .bar:hover::after { content: attr(data-val); position: absolute; top: -24px; left: 50%; transform: translateX(-50%); background: var(--surface3); color: var(--text); font-size: 10px; padding: 2px 6px; border-radius: 4px; white-space: nowrap; }
  .bar-label { font-size: 10px; color: var(--text3); }
  .chart-legend { display: flex; gap: 16px; margin-top: 8px; }
  .legend-item { display: flex; align-items: center; gap: 6px; font-size: 11px; color: var(--text2); }
  .legend-dot { width: 8px; height: 8px; border-radius: 2px; }

  /* STOCKS */
  .stock-warning { display: flex; align-items: center; gap: 8px; padding: 10px 14px; background: rgba(248,113,113,.1); border: 1px solid rgba(248,113,113,.2); border-radius: var(--radius-sm); margin-bottom: 16px; font-size: 13px; color: var(--red); }
  .progress-bar { width: 100%; height: 6px; background: var(--surface3); border-radius: 3px; overflow: hidden; }
  .progress-fill { height: 100%; border-radius: 3px; transition: width .5s; }
  .progress-green { background: var(--green); }
  .progress-yellow { background: var(--gold); }
  .progress-red { background: var(--red); }

  /* BILL */
  .bill-paper { background: #fff; color: #111; padding: 28px; max-width: 380px; border-radius: 8px; font-family: 'DM Sans', sans-serif; }
  .bill-paper .bill-hotel { text-align: center; font-family: 'Playfair Display', serif; font-size: 20px; font-weight: 700; margin-bottom: 4px; }
  .bill-paper .bill-sub { text-align: center; font-size: 11px; color: #666; margin-bottom: 16px; }
  .bill-divider { border: none; border-top: 1px dashed #ccc; margin: 12px 0; }
  .bill-row { display: flex; justify-content: space-between; font-size: 13px; margin-bottom: 4px; }
  .bill-total-row { display: flex; justify-content: space-between; font-size: 15px; font-weight: 700; border-top: 2px solid #111; padding-top: 8px; margin-top: 8px; }
  .bill-footer-txt { text-align: center; font-size: 11px; color: #666; margin-top: 12px; }
  .no-print { }
  @media print { .sidebar, .page-header, .btn, .no-print { display: none !important; } .main { width: 100%; } .bill-paper { max-width: 100%; } }

  /* NOTIFICATION */
  #notification { position: fixed; top: 20px; right: 20px; padding: 12px 20px; border-radius: var(--radius-sm); font-size: 13px; font-weight: 600; z-index: 9999; display: none; animation: slideIn .3s ease; }
  @keyframes slideIn { from { opacity:0; transform:translateX(50px); } to { opacity:1; transform:translateX(0); } }
  .notif-success { background: rgba(74,222,128,.2); border: 1px solid rgba(74,222,128,.3); color: var(--green); }
  .notif-error { background: rgba(248,113,113,.2); border: 1px solid rgba(248,113,113,.3); color: var(--red); }
  .notif-info { background: rgba(96,165,250,.2); border: 1px solid rgba(96,165,250,.3); color: var(--blue); }

  /* TABS */
  .tab-bar { display: flex; gap: 4px; background: var(--surface2); padding: 4px; border-radius: var(--radius-sm); margin-bottom: 20px; width: fit-content; }
  .tab-btn { padding: 7px 16px; border-radius: 6px; font-size: 13px; font-weight: 600; cursor: pointer; color: var(--text2); border: none; background: none; font-family: inherit; transition: all .2s; }
  .tab-btn.active { background: var(--surface); color: var(--text); box-shadow: 0 1px 4px rgba(0,0,0,.3); }
  .tab-content { display: none; } .tab-content.active { display: block; }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .stats-grid { grid-template-columns: 1fr 1fr; }
    .order-layout { grid-template-columns: 1fr; }
    .dashboard-grid { grid-template-columns: 1fr; }
    .menu-grid { grid-template-columns: 1fr 1fr; }
    .form-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 600px) {
    .sidebar { display: none; }
    .stats-grid { grid-template-columns: 1fr; }
  }
  .empty-state { text-align: center; padding: 40px; color: var(--text3); }
  .empty-state .empty-icon { font-size: 40px; margin-bottom: 10px; }
  .empty-state p { font-size: 14px; }
</style>
</head>
<body>

<div id="notification"></div>

<!-- BILL MODAL -->
<div class="modal-overlay" id="billModal">
  <div class="modal" style="max-width:420px;">
    <div class="modal-title">Bill Receipt <span class="close-btn" onclick="closeModal('billModal')">✕</span></div>
    <div id="billContent"></div>
    <div class="modal-footer no-print">
      <button class="btn btn-secondary btn-sm" onclick="closeModal('billModal')">Close</button>
      <button class="btn btn-primary btn-sm" onclick="window.print()">🖨️ Print</button>
    </div>
  </div>
</div>

<!-- ADD MENU ITEM MODAL -->
<div class="modal-overlay" id="menuModal">
  <div class="modal">
    <div class="modal-title" id="menuModalTitle">Add Menu Item <span class="close-btn" onclick="closeModal('menuModal')">✕</span></div>
    <div class="form-grid">
      <div class="form-group"><label>Item Name *</label><input id="mi_name" placeholder="e.g. Chicken Curry"></div>
      <div class="form-group"><label>Category *</label>
        <select id="mi_cat">
          <option value="Starters">Starters</option><option value="Main Course">Main Course</option>
          <option value="Beverages">Beverages</option><option value="Desserts">Desserts</option>
          <option value="Breads">Breads</option><option value="Rice & Noodles">Rice & Noodles</option>
        </select>
      </div>
      <div class="form-group"><label>Selling Price (NPR) *</label><input id="mi_price" type="number" placeholder="250"></div>
      <div class="form-group"><label>Cost Price (NPR) *</label><input id="mi_cost" type="number" placeholder="120"></div>
      <div class="form-group"><label>Stock Quantity</label><input id="mi_stock" type="number" placeholder="50"></div>
      <div class="form-group"><label>Min Stock Alert</label><input id="mi_minstock" type="number" placeholder="10"></div>
      <div class="form-group"><label>Emoji Icon</label><input id="mi_emoji" placeholder="🍛" maxlength="4"></div>
      <div class="form-group"><label>Available</label>
        <select id="mi_available"><option value="1">Yes</option><option value="0">No</option></select>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary btn-sm" onclick="closeModal('menuModal')">Cancel</button>
      <button class="btn btn-primary btn-sm" onclick="saveMenuItem()">Save Item</button>
    </div>
  </div>
</div>

<!-- ADD STAFF MODAL -->
<div class="modal-overlay" id="staffModal">
  <div class="modal">
    <div class="modal-title">Add Staff <span class="close-btn" onclick="closeModal('staffModal')">✕</span></div>
    <div class="form-grid">
      <div class="form-group"><label>Full Name *</label><input id="st_name" placeholder="John Doe"></div>
      <div class="form-group"><label>Role *</label>
        <select id="st_role">
          <option>Waiter</option><option>Chef</option><option>Cashier</option><option>Manager</option><option>Bartender</option>
        </select>
      </div>
      <div class="form-group"><label>Phone</label><input id="st_phone" placeholder="+977-..."></div>
      <div class="form-group"><label>Salary (NPR)</label><input id="st_salary" type="number" placeholder="25000"></div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary btn-sm" onclick="closeModal('staffModal')">Cancel</button>
      <button class="btn btn-primary btn-sm" onclick="saveStaff()">Save Staff</button>
    </div>
  </div>
</div>

<div class="app">
  <!-- SIDEBAR -->
  <div class="sidebar">
    <div class="sidebar-header">
      <div class="logo">
        <div class="logo-icon">🏨</div>
        <div>
          <div class="logo-text">Hotel HMS</div>
          <div class="logo-sub">Management Suite</div>
        </div>
      </div>
    </div>
    <div class="sidebar-nav">
      <div class="nav-section">
        <div class="nav-label">Overview</div>
        <div class="nav-item active" onclick="showPage('dashboard',this)"><span class="icon">📊</span> Dashboard</div>
      </div>
      <div class="nav-section">
        <div class="nav-label">Operations</div>
        <div class="nav-item" onclick="showPage('orders',this)"><span class="icon">📝</span> Take Order <span class="nav-badge" id="pendingBadge">0</span></div>
        <div class="nav-item" onclick="showPage('billing',this)"><span class="icon">🧾</span> Billing</div>
        <div class="nav-item" onclick="showPage('kitchen',this)"><span class="icon">👨‍🍳</span> Kitchen View</div>
      </div>
      <div class="nav-section">
        <div class="nav-label">Management</div>
        <div class="nav-item" onclick="showPage('menu',this)"><span class="icon">🍽️</span> Menu Items</div>
        <div class="nav-item" onclick="showPage('stock',this)"><span class="icon">📦</span> Stock</div>
        <div class="nav-item" onclick="showPage('staff',this)"><span class="icon">👥</span> Staff</div>
      </div>
      <div class="nav-section">
        <div class="nav-label">Finance</div>
        <div class="nav-item" onclick="showPage('reports',this)"><span class="icon">📈</span> P&L Report</div>
      </div>
    </div>
    <div class="sidebar-footer">
      <div class="staff-info">
        <div class="staff-avatar">M</div>
        <div>
          <div class="staff-name">Manager</div>
          <div class="staff-role">Admin Access</div>
        </div>
      </div>
    </div>
  </div>

  <!-- MAIN CONTENT -->
  <div class="main">

    <!-- DASHBOARD -->
    <div class="page active" id="page-dashboard">
      <div class="page-header">
        <div><div class="page-title">Dashboard</div><div class="page-sub" id="dashDate"></div></div>
        <div class="header-actions">
          <button class="btn btn-secondary btn-sm" onclick="seedSampleData()">🎲 Load Sample Data</button>
        </div>
      </div>
      <div class="page" style="display:block; padding-top:20px;" id="dashContent"></div>
    </div>

    <!-- ORDERS -->
    <div class="page" id="page-orders">
      <div class="page-header">
        <div><div class="page-title">New Order</div><div class="page-sub">Select items and place an order</div></div>
      </div>
      <div style="padding:20px 32px 0;">
        <div class="table-select-row">
          <label>Table No:</label>
          <select id="orderTable" style="width:120px;">
            <option value="T1">Table 1</option><option value="T2">Table 2</option><option value="T3">Table 3</option>
            <option value="T4">Table 4</option><option value="T5">Table 5</option><option value="T6">Table 6</option>
            <option value="T7">Table 7</option><option value="T8">Table 8</option><option value="T9">Table 9</option>
            <option value="T10">Table 10</option><option value="Takeaway">Takeaway</option>
          </select>
          <label style="margin-left:10px;">Waiter:</label>
          <select id="orderWaiter" style="width:150px;"></select>
          <div class="search-bar" style="margin-left:auto;">
            <input id="menuSearch" placeholder="Search menu..." oninput="filterMenu()" style="width:200px;">
          </div>
        </div>
        <div class="order-layout">
          <div>
            <div class="menu-category-tabs" id="catTabs"></div>
            <div class="menu-grid" id="menuGrid"></div>
          </div>
          <div class="order-cart">
            <div class="cart-header">🛒 Current Order</div>
            <div class="cart-items" id="cartItems"></div>
            <div class="cart-footer">
              <div class="cart-subtotal"><span>Subtotal</span><span id="cartSubtotal">NPR 0</span></div>
              <div class="cart-subtotal tax-line"><span>VAT (13%)</span><span id="cartVat">NPR 0</span></div>
              <div class="cart-subtotal tax-line"><span>Service (10%)</span><span id="cartService">NPR 0</span></div>
              <div class="cart-total"><span>Total</span><span id="cartTotal">NPR 0</span></div>
              <div style="margin-top:14px;display:flex;gap:8px;">
                <button class="btn btn-secondary btn-sm" style="flex:1" onclick="clearCart()">Clear</button>
                <button class="btn btn-primary" style="flex:2" onclick="placeOrder()">Place Order ✓</button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- BILLING -->
    <div class="page" id="page-billing">
      <div class="page-header">
        <div><div class="page-title">Billing</div><div class="page-sub">Manage and generate bills</div></div>
      </div>
      <div style="padding:20px 32px 0;">
        <div class="tab-bar">
          <button class="tab-btn active" onclick="switchTab('billing','pending',this)">Pending Bills</button>
          <button class="tab-btn" onclick="switchTab('billing','paid',this)">Paid Bills</button>
        </div>
        <div class="tab-content active" id="billing-pending-tab" data-group="billing"></div>
        <div class="tab-content" id="billing-paid-tab" data-group="billing"></div>
      </div>
    </div>

    <!-- KITCHEN -->
    <div class="page" id="page-kitchen">
      <div class="page-header">
        <div><div class="page-title">Kitchen View</div><div class="page-sub">Live order queue for kitchen staff</div></div>
        <button class="btn btn-secondary btn-sm" onclick="renderKitchen()">🔄 Refresh</button>
      </div>
      <div style="padding:20px 32px 0;" id="kitchenContent"></div>
    </div>

    <!-- MENU ITEMS -->
    <div class="page" id="page-menu">
      <div class="page-header">
        <div><div class="page-title">Menu Management</div><div class="page-sub">Manage your food and beverage items</div></div>
        <button class="btn btn-primary btn-sm" onclick="openMenuModal()">+ Add Item</button>
      </div>
      <div style="padding:20px 32px 0;" id="menuMgmtContent"></div>
    </div>

    <!-- STOCK -->
    <div class="page" id="page-stock">
      <div class="page-header">
        <div><div class="page-title">Stock Management</div><div class="page-sub">Track inventory levels</div></div>
      </div>
      <div style="padding:20px 32px 0;" id="stockContent"></div>
    </div>

    <!-- STAFF -->
    <div class="page" id="page-staff">
      <div class="page-header">
        <div><div class="page-title">Staff Management</div><div class="page-sub">Manage hotel staff</div></div>
        <button class="btn btn-primary btn-sm" onclick="openStaffModal()">+ Add Staff</button>
      </div>
      <div style="padding:20px 32px 0;" id="staffContent"></div>
    </div>

    <!-- REPORTS -->
    <div class="page" id="page-reports">
      <div class="page-header">
        <div><div class="page-title">Profit & Loss Report</div><div class="page-sub">Financial overview and analytics</div></div>
      </div>
      <div style="padding:20px 32px 0;" id="reportsContent"></div>
    </div>

  </div>
</div>

<script>
// ====== STATE ======
let DB = {
  menuItems: [],
  orders: [],
  staff: [],
  settings: { vatRate: 13, serviceRate: 10, hotelName: 'Grand Hotel HMS', address: 'Kathmandu, Nepal' }
};
let cart = [];
let editingMenuId = null;

// ====== PERSISTENCE ======
function save() { localStorage.setItem('hotel_hms', JSON.stringify(DB)); }
function load() {
  const d = localStorage.getItem('hotel_hms');
  if (d) DB = JSON.parse(d);
}

// ====== SEED DATA ======
function seedSampleData() {
  DB.menuItems = [
    {id:1, name:'Chicken Momos', cat:'Starters', price:220, cost:80, stock:40, minStock:10, emoji:'🥟', available:true},
    {id:2, name:'Veg Soup', cat:'Starters', price:150, cost:40, stock:30, minStock:8, emoji:'🍲', available:true},
    {id:3, name:'Chicken Curry', cat:'Main Course', price:350, cost:150, stock:25, minStock:5, emoji:'🍛', available:true},
    {id:4, name:'Dal Bhat', cat:'Main Course', price:280, cost:90, stock:50, minStock:10, emoji:'🍱', available:true},
    {id:5, name:'Veg Fried Rice', cat:'Rice & Noodles', price:250, cost:80, stock:30, minStock:8, emoji:'🍚', available:true},
    {id:6, name:'Noodles', cat:'Rice & Noodles', price:200, cost:60, stock:35, minStock:8, emoji:'🍜', available:true},
    {id:7, name:'Masala Tea', cat:'Beverages', price:80, cost:20, stock:100, minStock:20, emoji:'☕', available:true},
    {id:8, name:'Lassi', cat:'Beverages', price:120, cost:40, stock:25, minStock:5, emoji:'🥛', available:true},
    {id:9, name:'Cold Coffee', cat:'Beverages', price:180, cost:60, stock:20, minStock:5, emoji:'🧋', available:true},
    {id:10, name:'Chocolate Brownie', cat:'Desserts', price:200, cost:70, stock:15, minStock:5, emoji:'🍫', available:true},
    {id:11, name:'Ice Cream', cat:'Desserts', price:150, cost:50, stock:20, minStock:5, emoji:'🍨', available:true},
    {id:12, name:'Garlic Bread', cat:'Breads', price:120, cost:35, stock:25, minStock:5, emoji:'🥖', available:true},
    {id:13, name:'Butter Naan', cat:'Breads', price:60, cost:20, stock:60, minStock:15, emoji:'🫓', available:true},
    {id:14, name:'Buff Steak', cat:'Main Course', price:550, cost:250, stock:6, minStock:5, emoji:'🥩', available:true},
    {id:15, name:'Spring Roll', cat:'Starters', price:180, cost:60, stock:3, minStock:5, emoji:'🌯', available:true},
  ];
  DB.staff = [
    {id:1, name:'Ram Sharma', role:'Waiter', phone:'9841000001', salary:22000, active:true},
    {id:2, name:'Sita Thapa', role:'Chef', phone:'9841000002', salary:35000, active:true},
    {id:3, name:'Hari Poudel', role:'Waiter', phone:'9841000003', salary:22000, active:true},
    {id:4, name:'Gita Karki', role:'Cashier', phone:'9841000004', salary:25000, active:true},
  ];
  // Generate some past orders
  const now = Date.now();
  const day = 86400000;
  DB.orders = [];
  let orderId = 1;
  for (let d = 6; d >= 0; d--) {
    const numOrders = Math.floor(Math.random()*6)+4;
    for (let o = 0; o < numOrders; o++) {
      const items = [];
      const numItems = Math.floor(Math.random()*4)+1;
      for (let i = 0; i < numItems; i++) {
        const mi = DB.menuItems[Math.floor(Math.random()*DB.menuItems.length)];
        const qty = Math.floor(Math.random()*3)+1;
        items.push({id:mi.id, name:mi.name, price:mi.price, cost:mi.cost, qty});
      }
      const sub = items.reduce((s,it)=>s+it.price*it.qty,0);
      const vat = Math.round(sub*0.13);
      const srv = Math.round(sub*0.10);
      DB.orders.push({
        id:orderId++,
        table:'T'+(Math.floor(Math.random()*8)+1),
        waiter: DB.staff[Math.floor(Math.random()*DB.staff.length)].name,
        items, subtotal:sub, vat, service:srv, total:sub+vat+srv,
        status: d===0 && o<2 ? 'pending' : 'paid',
        timestamp: now - d*day - Math.floor(Math.random()*3600000*8),
        paidAt: d===0 && o<2 ? null : now - d*day
      });
    }
  }
  save();
  notify('✅ Sample data loaded!', 'success');
  renderAll();
  updatePendingBadge();
}

// ====== NAVIGATION ======
function showPage(name, el) {
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  document.getElementById('page-'+name).classList.add('active');
  if(el) el.classList.add('active');
  renderPage(name);
}

function renderPage(name) {
  switch(name) {
    case 'dashboard': renderDashboard(); break;
    case 'orders': renderOrderPage(); break;
    case 'billing': renderBilling(); break;
    case 'kitchen': renderKitchen(); break;
    case 'menu': renderMenuMgmt(); break;
    case 'stock': renderStock(); break;
    case 'staff': renderStaff(); break;
    case 'reports': renderReports(); break;
  }
}

function renderAll() { renderDashboard(); updatePendingBadge(); }

// ====== DASHBOARD ======
function renderDashboard() {
  const today = new Date();
  document.getElementById('dashDate').textContent = today.toLocaleDateString('en-US',{weekday:'long',year:'numeric',month:'long',day:'numeric'});
  const todayOrders = DB.orders.filter(o=>{
    const d = new Date(o.timestamp);
    return d.toDateString() === today.toDateString();
  });
  const todayRevenue = todayOrders.filter(o=>o.status==='paid').reduce((s,o)=>s+o.total,0);
  const totalRevenue = DB.orders.filter(o=>o.status==='paid').reduce((s,o)=>s+o.total,0);
  const totalCost = DB.orders.filter(o=>o.status==='paid').reduce((s,o)=>s+o.items.reduce((c,i)=>c+i.cost*i.qty,0),0);
  const pendingOrders = DB.orders.filter(o=>o.status==='pending').length;
  const lowStock = DB.menuItems.filter(m=>m.stock<=m.minStock).length;

  // Top items
  const itemCounts = {};
  DB.orders.filter(o=>o.status==='paid').forEach(o=>o.items.forEach(i=>{
    itemCounts[i.name] = (itemCounts[i.name]||0)+i.qty;
  }));
  const topItems = Object.entries(itemCounts).sort((a,b)=>b[1]-a[1]).slice(0,5);

  // Weekly bars
  const weekData = [];
  for(let d=6;d>=0;d--){
    const dt = new Date(); dt.setDate(dt.getDate()-d);
    const dayOrders = DB.orders.filter(o=>{
      const od = new Date(o.timestamp);
      return od.toDateString()===dt.toDateString() && o.status==='paid';
    });
    const rev = dayOrders.reduce((s,o)=>s+o.total,0);
    const cost = dayOrders.reduce((s,o)=>s+o.items.reduce((c,i)=>c+i.cost*i.qty,0),0);
    weekData.push({label:dt.toLocaleDateString('en-US',{weekday:'short'}), rev, cost});
  }
  const maxBar = Math.max(...weekData.map(w=>w.rev),1);

  const recentOrders = [...DB.orders].sort((a,b)=>b.timestamp-a.timestamp).slice(0,6);

  document.getElementById('dashContent').innerHTML = `
    <div class="stats-grid">
      <div class="stat-card gold">
        <div class="stat-icon">💰</div>
        <div class="stat-value">₨${fmt(todayRevenue)}</div>
        <div class="stat-label">Today's Revenue</div>
        <div class="stat-change up">↑ Today</div>
      </div>
      <div class="stat-card teal">
        <div class="stat-icon">📝</div>
        <div class="stat-value">${todayOrders.length}</div>
        <div class="stat-label">Today's Orders</div>
        <div class="stat-change ${pendingOrders>0?'down':'up'}">${pendingOrders} pending</div>
      </div>
      <div class="stat-card green">
        <div class="stat-icon">📈</div>
        <div class="stat-value">₨${fmt(totalRevenue-totalCost)}</div>
        <div class="stat-label">Total Profit</div>
        <div class="stat-change up">${totalRevenue>0?Math.round((totalRevenue-totalCost)/totalRevenue*100):0}% margin</div>
      </div>
      <div class="stat-card red">
        <div class="stat-icon">📦</div>
        <div class="stat-value">${lowStock}</div>
        <div class="stat-label">Low Stock Items</div>
        <div class="stat-change ${lowStock>0?'down':'up'}">${lowStock>0?'⚠️ Needs restock':'All good'}</div>
      </div>
    </div>
    <div class="dashboard-grid">
      <div class="card">
        <div class="card-title">Weekly Revenue vs Cost</div>
        <div class="bar-chart" id="weekChart">
          ${weekData.map(w=>`
            <div class="bar-group">
              <div style="display:flex;align-items:flex-end;gap:2px;height:140px">
                <div class="bar revenue" style="height:${Math.round(w.rev/maxBar*130)}px;min-height:2px;width:20px" data-val="₨${fmt(w.rev)}"></div>
                <div class="bar cost" style="height:${Math.round(w.cost/maxBar*130)}px;min-height:2px;width:14px" data-val="₨${fmt(w.cost)}"></div>
              </div>
              <div class="bar-label">${w.label}</div>
            </div>
          `).join('')}
        </div>
        <div class="chart-legend">
          <div class="legend-item"><div class="legend-dot" style="background:var(--gold)"></div>Revenue</div>
          <div class="legend-item"><div class="legend-dot" style="background:var(--red)"></div>Cost</div>
        </div>
      </div>
      <div class="card">
        <div class="card-title">Top Selling Items</div>
        <div class="top-items-list">
          ${topItems.length===0?'<div class="empty-state"><div class="empty-icon">🍽️</div><p>No orders yet</p></div>':topItems.map((t,i)=>`
            <div class="top-item-row">
              <div class="top-item-rank ${i===0?'rank-1':i===1?'rank-2':i===2?'rank-3':'rank-other'}">${i+1}</div>
              <div class="top-item-name">${t[0]}</div>
              <div class="top-item-count">${t[1]} sold</div>
            </div>
          `).join('')}
        </div>
      </div>
    </div>
    <div class="card" style="margin-top:20px;">
      <div class="card-title">Recent Orders</div>
      <div class="recent-orders-list" style="margin-top:10px;">
        ${recentOrders.length===0?'<div class="empty-state"><div class="empty-icon">📋</div><p>No orders yet. Use "Load Sample Data" to get started.</p></div>':recentOrders.map(o=>`
          <div class="order-row">
            <div class="order-row-num">#${o.id}</div>
            <div class="order-row-info">
              <div class="name">${o.table} • ${o.waiter}</div>
              <div class="time">${new Date(o.timestamp).toLocaleString()}</div>
            </div>
            <span class="badge badge-${o.status==='pending'?'pending':'done'}">${o.status}</span>
            <div class="order-row-amount">₨${fmt(o.total)}</div>
          </div>
        `).join('')}
      </div>
    </div>
  `;
}

// ====== ORDER PAGE ======
function renderOrderPage() {
  // Waiters dropdown
  const waiterSel = document.getElementById('orderWaiter');
  waiterSel.innerHTML = DB.staff.filter(s=>s.active).map(s=>`<option>${s.name}</option>`).join('');
  if(!waiterSel.innerHTML) waiterSel.innerHTML = '<option>Staff 1</option>';
  renderCatTabs();
  renderMenuGrid();
  renderCart();
}

let activeCat = 'All';
function renderCatTabs() {
  const cats = ['All',...new Set(DB.menuItems.map(m=>m.cat))];
  document.getElementById('catTabs').innerHTML = cats.map(c=>`
    <div class="cat-tab ${c===activeCat?'active':''}" onclick="setCat('${c}')">${c}</div>
  `).join('');
}

function setCat(cat) { activeCat=cat; renderCatTabs(); renderMenuGrid(); }

function filterMenu() {
  activeCat='All'; renderCatTabs(); renderMenuGrid();
}

function renderMenuGrid() {
  const q = (document.getElementById('menuSearch')||{value:''}).value.toLowerCase();
  let items = DB.menuItems.filter(m=>m.available);
  if(activeCat!=='All') items = items.filter(m=>m.cat===activeCat);
  if(q) items = items.filter(m=>m.name.toLowerCase().includes(q)||m.cat.toLowerCase().includes(q));
  if(items.length===0){ document.getElementById('menuGrid').innerHTML='<div class="empty-state" style="grid-column:1/-1"><div class="empty-icon">🍽️</div><p>No items found</p></div>'; return; }
  document.getElementById('menuGrid').innerHTML = items.map(m=>`
    <div class="menu-item ${m.stock<=0?'opacity-50':''}" onclick="${m.stock>0?`addToCart(${m.id})`:''}">
      <div style="font-size:28px;margin-bottom:6px">${m.emoji||'🍽️'}</div>
      <div class="item-name">${m.name}</div>
      <div class="item-cat">${m.cat}</div>
      <div style="display:flex;justify-content:space-between;align-items:center">
        <div class="item-price">₨${m.price}</div>
        ${m.stock<=m.minStock?`<span style="font-size:10px;color:var(--red)">Low:${m.stock}</span>`:''}
        ${m.stock<=0?'<span style="font-size:10px;color:var(--red)">Out</span>':''}
      </div>
    </div>
  `).join('');
}

function addToCart(itemId) {
  const item = DB.menuItems.find(m=>m.id===itemId);
  if(!item||item.stock<=0) return;
  const existing = cart.find(c=>c.id===itemId);
  if(existing){ existing.qty++; }
  else { cart.push({id:item.id,name:item.name,price:item.price,cost:item.cost,qty:1,emoji:item.emoji}); }
  renderCart();
}

function removeFromCart(itemId) {
  const idx = cart.findIndex(c=>c.id===itemId);
  if(idx===-1) return;
  if(cart[idx].qty>1) cart[idx].qty--;
  else cart.splice(idx,1);
  renderCart();
}

function clearCart() { cart=[]; renderCart(); }

function renderCart() {
  const el = document.getElementById('cartItems');
  if(cart.length===0){ el.innerHTML='<div class="empty-state"><div class="empty-icon">🛒</div><p>Cart is empty</p></div>'; }
  else {
    el.innerHTML = cart.map(c=>`
      <div class="cart-item">
        <div style="font-size:18px">${c.emoji||'🍽️'}</div>
        <div class="cart-item-name">${c.name}</div>
        <div class="qty-ctrl">
          <div class="qty-btn" onclick="removeFromCart(${c.id})">−</div>
          <div class="qty-num">${c.qty}</div>
          <div class="qty-btn" onclick="addToCart(${c.id})">+</div>
        </div>
        <div class="cart-item-price">₨${fmt(c.price*c.qty)}</div>
      </div>
    `).join('');
  }
  const sub = cart.reduce((s,c)=>s+c.price*c.qty,0);
  const vat = Math.round(sub*DB.settings.vatRate/100);
  const srv = Math.round(sub*DB.settings.serviceRate/100);
  const total = sub+vat+srv;
  document.getElementById('cartSubtotal').textContent = `₨${fmt(sub)}`;
  document.getElementById('cartVat').textContent = `₨${fmt(vat)}`;
  document.getElementById('cartService').textContent = `₨${fmt(srv)}`;
  document.getElementById('cartTotal').textContent = `₨${fmt(total)}`;
}

function placeOrder() {
  if(cart.length===0){ notify('Cart is empty!','error'); return; }
  const table = document.getElementById('orderTable').value;
  const waiter = document.getElementById('orderWaiter').value||'Staff';
  const sub = cart.reduce((s,c)=>s+c.price*c.qty,0);
  const vat = Math.round(sub*DB.settings.vatRate/100);
  const srv = Math.round(sub*DB.settings.serviceRate/100);
  const order = {
    id: DB.orders.length>0?Math.max(...DB.orders.map(o=>o.id))+1:1,
    table, waiter,
    items: cart.map(c=>({...c})),
    subtotal:sub, vat, service:srv, total:sub+vat+srv,
    status:'pending',
    timestamp:Date.now(),
    paidAt:null
  };
  // Deduct stock
  cart.forEach(c=>{
    const mi = DB.menuItems.find(m=>m.id===c.id);
    if(mi) mi.stock = Math.max(0, mi.stock - c.qty);
  });
  DB.orders.push(order);
  save();
  cart=[];
  renderCart();
  updatePendingBadge();
  notify(`✅ Order #${order.id} placed for ${table}!`,'success');
}

// ====== BILLING ======
function renderBilling() {
  const pending = DB.orders.filter(o=>o.status==='pending').sort((a,b)=>b.timestamp-a.timestamp);
  const paid = DB.orders.filter(o=>o.status==='paid').sort((a,b)=>b.timestamp-a.timestamp).slice(0,30);

  document.getElementById('billing-pending-tab').innerHTML = pending.length===0?
    '<div class="empty-state"><div class="empty-icon">✅</div><p>No pending bills</p></div>' :
    `<div class="table-wrap"><table>
      <thead><tr><th>#Order</th><th>Table</th><th>Waiter</th><th>Items</th><th>Subtotal</th><th>VAT</th><th>Service</th><th>Total</th><th>Time</th><th>Actions</th></tr></thead>
      <tbody>${pending.map(o=>`
        <tr>
          <td><strong>#${o.id}</strong></td>
          <td>${o.table}</td><td>${o.waiter}</td>
          <td>${o.items.map(i=>`${i.emoji||''}${i.name}×${i.qty}`).join(', ')}</td>
          <td>₨${fmt(o.subtotal)}</td><td>₨${fmt(o.vat)}</td><td>₨${fmt(o.service)}</td>
          <td><strong>₨${fmt(o.total)}</strong></td>
          <td>${new Date(o.timestamp).toLocaleTimeString()}</td>
          <td style="display:flex;gap:6px;">
            <button class="btn btn-sm btn-success" onclick="markPaid(${o.id})">✓ Pay</button>
            <button class="btn btn-sm btn-secondary" onclick="showBill(${o.id})">🧾</button>
          </td>
        </tr>`).join('')}
      </tbody></table></div>`;

  document.getElementById('billing-paid-tab').innerHTML = paid.length===0?
    '<div class="empty-state"><div class="empty-icon">📄</div><p>No paid orders</p></div>' :
    `<div class="table-wrap"><table>
      <thead><tr><th>#Order</th><th>Table</th><th>Waiter</th><th>Total</th><th>Paid At</th><th>Bill</th></tr></thead>
      <tbody>${paid.map(o=>`
        <tr>
          <td><strong>#${o.id}</strong></td>
          <td>${o.table}</td><td>${o.waiter}</td>
          <td><strong>₨${fmt(o.total)}</strong></td>
          <td>${o.paidAt?new Date(o.paidAt).toLocaleString():'-'}</td>
          <td><button class="btn btn-sm btn-secondary" onclick="showBill(${o.id})">🧾 View</button></td>
        </tr>`).join('')}
      </tbody></table></div>`;
}

function markPaid(orderId) {
  const o = DB.orders.find(o=>o.id===orderId);
  if(o){ o.status='paid'; o.paidAt=Date.now(); save(); updatePendingBadge(); renderBilling(); renderDashboard(); notify(`✅ Order #${orderId} marked as paid!`,'success'); }
}

