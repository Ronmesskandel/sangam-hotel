      <hr class="bill-divider">
      <div class="bill-row" style="font-weight:700;font-size:12px;color:#666;text-transform:uppercase"><span>Item</span><span>Qty × Price = Total</span></div>
      ${o.items.map(i=>`<div class="bill-row"><span>${i.emoji||''}${i.name}</span><span>${i.qty} × ₨${i.price} = ₨${fmt(i.price*i.qty)}</span></div>`).join('')}
